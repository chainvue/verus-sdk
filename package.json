{
  "name": "@chainvue/verus-sdk",
  "version": "0.6.3",
  "description": "100% offline, fully typed TypeScript SDK for Verus transaction signing",
  "author": "Robert Lech",
  "main": "dist/bundle.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && node scripts/finalize-types.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build && pnpm run bundle && pnpm run typecheck && pnpm run lint && pnpm run test",
    "bundle": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.eslint.json",
    "lint": "eslint ."
  },
  "keywords": [
    "verus",
    "cryptocurrency",
    "offline-signing",
    "typescript"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/chainvue/verus-sdk.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "bn.js": "^5.2.2",
    "bs58check": "^2.1.2",
    "create-hash": "^1.2.0",
    "ecpair": "^2.1.0",
    "tiny-secp256k1": "^2.2.4",
    "wif": "^4.0.0"
  },
  "devDependencies": {
    "@bitgo/utxo-lib": "github:VerusCoin/BitGoJS#9701df63b479984f27680348f9671c2d40025a90",
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@types/bn.js": "^5.2.0",
    "@types/bs58check": "^2.1.2",
    "@types/create-hash": "^1.2.6",
    "@types/node": "^20.19.33",
    "@vitest/coverage-v8": "^4.1.10",
    "bitcoin-ops": "github:VerusCoin/bitcoin-ops#a5f8f56e658301bc39881d41740b3a0010530efd",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "semantic-release": "^25.0.7",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "verus-typescript-primitives": "github:VerusCoin/verus-typescript-primitives#4243cd075b4f68df1ce72fd2fd9c9b18ac36767e",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/**/*",
    "NOTICE",
    "LICENSE"
  ],
  "packageManager": "pnpm@10.34.5",
  "pnpm": {
    "overrides": {
      "bitcoin-ops": "github:VerusCoin/bitcoin-ops#a5f8f56e658301bc39881d41740b3a0010530efd",
      "verus-typescript-primitives": "github:VerusCoin/verus-typescript-primitives#4243cd075b4f68df1ce72fd2fd9c9b18ac36767e"
    },
    "patchedDependencies": {
      "bitcoin-ops": "patches/bitcoin-ops.patch"
    }
  }
}
